---
import BaseLayout from './BaseLayout.astro';
import Icon from '../components/Icon.astro';

interface Props {
  title: string;
  description: string;
  repo?: string;
  link?: string;
  tags?: string[];
}

const { title, description, repo, link, tags = [] } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={title} description={description}>
  <a href={`${base}/projects/`} class="mb-8 inline-flex items-center gap-1.5 text-xs font-semibold text-zinc-500 no-underline transition-colors hover:text-zinc-300">
    <span class="rotate-180"><Icon name="arrow-right" size={14} /></span> All projects
  </a>

  <article class="relative overflow-hidden rounded-3xl border border-white/5 bg-[#110b22]/70 p-6 shadow-2xl sm:p-9">
    <div class="accent-gradient pointer-events-none absolute right-0 top-0 h-40 w-40 rounded-tr-3xl opacity-[0.07] blur-2xl"></div>

    <header class="relative space-y-4">
      <h1 class="text-3xl font-black leading-tight tracking-tight sm:text-4xl">{title}</h1>
      <p class="text-lg text-zinc-400">{description}</p>
      {
        (link || repo) && (
          <div class="flex flex-wrap gap-3">
            {link && (
              <a href={link} class="accent-gradient flex items-center gap-2 rounded-xl px-4 py-2 text-sm font-bold text-white no-underline transition-opacity hover:opacity-90">
                <Icon name="external-link" size={15} /> Live
              </a>
            )}
            {repo && (
              <a href={repo} class="flex items-center gap-2 rounded-xl border border-white/10 bg-[#1c1233] px-4 py-2 text-sm font-bold text-zinc-200 no-underline transition-colors hover:border-white/20 hover:text-white">
                <Icon name="github" size={15} /> Source
              </a>
            )}
          </div>
        )
      }
      {
        tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="accent-badge rounded-full px-2.5 py-0.5 text-xs font-semibold">#{tag}</span>
            ))}
          </div>
        )
      }
    </header>

    <hr class="my-7 border-white/10" />

    <div class="prose-glass relative max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
