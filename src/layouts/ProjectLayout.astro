---
import BaseLayout from './BaseLayout.astro';
import Icon from '../components/Icon.astro';

interface Props {
  title: string;
  description: string;
  repo?: string;
  link?: string;
  tags?: string[];
}

const { title, description, repo, link, tags = [] } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={title} description={description}>
  <a href={`${base}/projects/`} class="mb-8 inline-flex items-center gap-1.5 font-mono text-[11px] uppercase tracking-widest text-zinc-500 no-underline transition-colors hover:text-zinc-200">
    <span class="rotate-180"><Icon name="arrow-right" size={13} /></span> All projects
  </a>

  <article class="relative overflow-hidden rounded-2xl border border-white/5 bg-zinc-950/40 p-6 shadow-2xl backdrop-blur-sm sm:p-9">
    <span class="glossy-top"></span>

    <header class="space-y-4">
      <h1 class="font-display text-3xl font-extrabold leading-tight tracking-tight text-white sm:text-4xl">{title}</h1>
      <p class="text-lg font-light text-zinc-400">{description}</p>
      {
        (link || repo) && (
          <div class="flex flex-wrap gap-3">
            {link && (
              <a href={link} class="accent-gradient inline-flex items-center gap-2 rounded-xl px-4 py-2 text-xs font-semibold text-white no-underline transition-opacity hover:opacity-90">
                <Icon name="external-link" size={14} /> Live
              </a>
            )}
            {repo && (
              <a href={repo} class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-zinc-900 px-4 py-2 text-xs font-semibold text-zinc-200 no-underline transition-colors hover:border-white/20 hover:text-white">
                <Icon name="github" size={14} /> Source
              </a>
            )}
          </div>
        )
      }
      {
        tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="accent-badge rounded-full px-2.5 py-0.5 font-mono text-[11px]">#{tag}</span>
            ))}
          </div>
        )
      }
    </header>

    <hr class="my-7 border-white/10" />

    <div class="prose-glass max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
