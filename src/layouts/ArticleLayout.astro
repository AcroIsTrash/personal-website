---
import BaseLayout from './BaseLayout.astro';
import Icon from '../components/Icon.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  readTime?: string;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, readTime, tags = [] } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={title} description={description}>
  <a href={`${base}/articles/`} class="mb-8 inline-flex items-center gap-1.5 text-xs font-semibold text-zinc-500 no-underline transition-colors hover:text-zinc-300">
    <span class="rotate-180"><Icon name="arrow-right" size={14} /></span> All articles
  </a>

  <article class="relative overflow-hidden rounded-3xl border border-white/5 bg-[#110b22]/70 p-6 shadow-2xl sm:p-9">
    <div class="accent-gradient pointer-events-none absolute right-0 top-0 h-40 w-40 rounded-tr-3xl opacity-[0.07] blur-2xl"></div>

    <header class="relative space-y-4">
      <div class="flex flex-wrap items-center gap-2 text-xs text-zinc-500">
        <span>{fmt(pubDate)}</span>
        {readTime && (<><span>&bull;</span><span>{readTime}</span></>)}
        {updatedDate && (<><span>&bull;</span><span>Updated {fmt(updatedDate)}</span></>)}
      </div>
      <h1 class="text-3xl font-black leading-tight tracking-tight sm:text-4xl">{title}</h1>
      {
        tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="accent-badge rounded-full px-2.5 py-0.5 text-xs font-semibold">#{tag}</span>
            ))}
          </div>
        )
      }
    </header>

    <hr class="my-7 border-white/10" />

    <div class="prose-glass relative max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
