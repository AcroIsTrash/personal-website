---
import BaseLayout from './BaseLayout.astro';
import Icon from '../components/Icon.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  readTime?: string;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, readTime, tags = [] } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={title} description={description}>
  <a href={`${base}/articles/`} class="mb-8 inline-flex items-center gap-1.5 font-mono text-[11px] uppercase tracking-widest text-zinc-500 no-underline transition-colors hover:text-zinc-200">
    <span class="rotate-180"><Icon name="arrow-right" size={13} /></span> All articles
  </a>

  <article class="relative overflow-hidden rounded-2xl border border-white/5 bg-zinc-950/40 p-6 shadow-2xl backdrop-blur-sm sm:p-9">
    <span class="glossy-top"></span>

    <header class="space-y-4">
      <div class="flex flex-wrap items-center gap-3 font-mono text-[10px] uppercase tracking-wider text-zinc-500">
        <span>{fmt(pubDate)}</span>
        {readTime && (<><span>&bull;</span><span>{readTime}</span></>)}
        {updatedDate && (<><span>&bull;</span><span>Updated {fmt(updatedDate)}</span></>)}
      </div>
      <h1 class="font-display text-3xl font-extrabold leading-tight tracking-tight text-white sm:text-4xl">{title}</h1>
      {
        tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="accent-badge rounded-full px-2.5 py-0.5 font-mono text-[11px]">#{tag}</span>
            ))}
          </div>
        )
      }
    </header>

    <hr class="my-7 border-white/10" />

    <div class="prose-glass max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
