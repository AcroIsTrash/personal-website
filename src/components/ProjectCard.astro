---
import Icon from './Icon.astro';

interface Props {
  href: string;
  title: string;
  description: string;
  tags?: string[];
  repo?: string;
  link?: string;
  category?: string;
  variant?: 'compact' | 'full';
}

const { href, title, description, tags = [], repo, link, category, variant = 'compact' } = Astro.props;
const full = variant === 'full';
---

<div
  class:list={[
    'group relative overflow-hidden rounded-2xl border border-white/5 bg-[#130e23]/60 p-5 transition-all duration-300 hover:border-white/10 hover:bg-[#191330]/80',
    full && 'flex flex-col justify-between',
  ]}
  data-filter
  data-category={category ?? ''}
>
  <div class="accent-gradient pointer-events-none absolute right-0 top-0 h-24 w-24 rounded-tr-2xl opacity-[0.06] blur-2xl transition-opacity group-hover:opacity-[0.12]"></div>

  <div class="relative space-y-4">
    <div class="flex items-center justify-between">
      {
        full ? (
          <span class="accent-text rounded-xl border border-white/5 bg-[#1a0f2e] p-2">
            <Icon name="folder-git-2" size={16} />
          </span>
        ) : (
          <h3 class="text-base font-bold text-zinc-200 transition-colors group-hover:text-white">
            <a href={href} class="no-underline">{title}</a>
          </h3>
        )
      }
      <div class="flex items-center gap-1.5">
        {repo && (
          <a href={repo} aria-label="Source" class="rounded-lg p-1.5 text-zinc-400 transition-all hover:bg-white/5 hover:text-white">
            <Icon name="github" size={15} />
          </a>
        )}
        {link && (
          <a href={link} aria-label="Live" class="rounded-lg p-1.5 text-zinc-400 transition-all hover:bg-white/5 hover:text-white">
            <Icon name="external-link" size={15} />
          </a>
        )}
      </div>
    </div>

    {
      full && (
        <div class="space-y-1">
          <h3 class="text-lg font-bold text-zinc-100 transition-colors group-hover:text-white">
            <a href={href} class="no-underline">{title}</a>
          </h3>
        </div>
      )
    }

    <p class:list={['text-xs leading-relaxed text-zinc-400', full && 'min-h-[48px]']}>{description}</p>
  </div>

  <div class:list={['relative', full ? 'mt-4 flex items-center justify-between border-t border-white/5 pt-4' : 'pt-3']}>
    <div class="flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <span class="text-[10px] font-bold uppercase tracking-wider text-zinc-500">#{tag}</span>
      ))}
    </div>
    {
      full && category && (
        <span class="accent-badge rounded px-2 py-0.5 text-[10px] font-black uppercase">{category}</span>
      )
    }
  </div>
</div>
