---
import TagList from './TagList.astro';
import { accentFor } from '../utils/accent';

interface Props {
  href: string;
  title: string;
  description: string;
  tags?: string[];
  repo?: string;
  link?: string;
}

const { href, title, description, tags = [], repo, link } = Astro.props;
---

<li class="card" style={`--card-accent: ${accentFor(title)}`}>
  <h3><a href={href}>{title}</a></h3>
  <p>{description}</p>
  <p class="links">
    {link && <a href={link}>Live ↗</a>}
    {repo && <a href={repo}>Source ↗</a>}
  </p>
  <TagList tags={tags} />
</li>

<style>
  .links {
    display: flex;
    gap: 1rem;
    margin: 0.6rem 0 0;
    font-size: 0.9rem;
    font-weight: 500;
  }
</style>
