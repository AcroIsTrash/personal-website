---
import Icon from './Icon.astro';

interface Props {
  href: string;
  title: string;
  description: string;
  tags?: string[];
  repo?: string;
  link?: string;
  index?: number;
  total?: number;
  variant?: 'compact' | 'full';
}

const { href, title, description, tags = [], repo, link, index, total, variant = 'compact' } = Astro.props;
const full = variant === 'full';

const category = tags.slice(0, 2).join(' + ').toUpperCase();
const num =
  index && total ? `${String(index).padStart(2, '0')} / ${String(total).padStart(2, '0')}` : '';
const primary = link ?? repo;
const primaryLabel = link ? 'View Live' : 'View Source';
---

<div
  class:list={[
    'group relative flex flex-col justify-between rounded-2xl border border-white/5 bg-zinc-900/30 p-6 transition-all duration-300 hover:border-white/20 hover:shadow-[0_10px_30px_rgba(0,0,0,0.5)]',
    full && 'h-72',
  ]}
  data-filter
  data-category={tags[0] ?? ''}
>
  <div class="space-y-3">
    <div class="flex items-center justify-between">
      <span class="font-mono text-[10px] tracking-wider text-zinc-500">{category || 'PROJECT'}</span>
      {num && <span class="font-mono text-[10px] text-zinc-600">{num}</span>}
    </div>
    <h3 class="font-display text-xl font-bold text-white transition-colors duration-300 group-hover:[color:var(--acc-text)]">
      <a href={href} class="no-underline before:absolute before:inset-0">{title}</a>
    </h3>
    <p class="text-xs font-light leading-relaxed text-zinc-400">{description}</p>
  </div>

  <div class="mt-6 flex items-center justify-between border-t border-white/5 pt-6">
    {
      primary ? (
        <a href={primary} class="group/link relative z-10 flex items-center gap-1.5 font-mono text-xs text-zinc-300 no-underline transition-colors hover:text-white">
          {primaryLabel} <Icon name="external-link" size={11} class="text-zinc-500 transition-colors group-hover/link:text-white" />
        </a>
      ) : (
        <span class="font-mono text-xs text-zinc-600">Case study</span>
      )
    }
    <span class="font-mono text-xs text-zinc-500">{repo && link ? 'Source + Live' : tags[0] ?? ''}</span>
  </div>
</div>
