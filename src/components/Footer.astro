---
import Icon from './Icon.astro';
import { site } from '../config';

const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="mt-24 border-t border-white/5 bg-[#090610] py-12">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 text-xs text-zinc-500 md:flex-row">
    <p>&copy; {year} {site.name}. Built with Astro.</p>
    <div class="flex items-center gap-4">
      <a href={`${base}/articles/`} class="transition-colors hover:text-zinc-300">Articles</a>
      <span>&bull;</span>
      <a href={`${base}/rss.xml`} class="transition-colors hover:text-zinc-300">RSS Feed</a>
      <span>&bull;</span>
      <span class="flex items-center gap-1">
        Made with <Icon name="heart" size={12} class="accent-text" />
      </span>
    </div>
  </div>
</footer>
