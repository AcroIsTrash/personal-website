---
import Icon from './Icon.astro';
import { site, social } from '../config';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const here = Astro.url.pathname.replace(/\/$/, '') || '/';

const links = [
  { href: `${base}/`, label: 'Home', match: (p: string) => p === (base || '/') },
  { href: `${base}/articles/`, label: 'Articles', match: (p: string) => p.startsWith(`${base}/articles`) },
  { href: `${base}/projects/`, label: 'Projects', match: (p: string) => p.startsWith(`${base}/projects`) },
  { href: `${base}/about/`, label: 'About', match: (p: string) => p.startsWith(`${base}/about`) },
];
---

<header class="relative z-10 mx-auto flex w-full max-w-5xl items-center justify-between px-6 py-6 md:py-8">
  <!-- Logo -->
  <a href={`${base}/`} class="group flex items-center gap-3 no-underline">
    <span class="flex h-9 w-9 items-center justify-center rounded-full border border-white/10 bg-zinc-900 transition-all duration-300 group-hover:border-white/30">
      <span class="accent-text font-display text-sm font-bold">a</span>
    </span>
    <span class="font-display text-xs font-semibold uppercase tracking-wider text-zinc-300 transition-all duration-300 group-hover:text-white">
      {site.name}
    </span>
  </a>

  <!-- Nav -->
  <nav class="hidden items-center gap-8 font-mono text-[11px] tracking-widest text-zinc-400 sm:flex">
    {
      links.map((link) => {
        const active = link.match(here);
        return (
          <a
            href={link.href}
            aria-current={active ? 'page' : undefined}
            class:list={[
              'link-underline py-1 uppercase transition-all duration-300 no-underline hover:text-white',
              active ? 'text-white' : '',
            ]}
          >
            {link.label}
          </a>
        );
      })
    }
  </nav>

  <!-- Socials -->
  <div class="flex items-center gap-3">
    <a href={social.github} class="flex h-8 w-8 items-center justify-center rounded-full border border-white/5 bg-zinc-900/50 text-zinc-400 transition-all duration-300 hover:border-white/20 hover:text-white" aria-label="GitHub">
      <Icon name="github" size={15} />
    </a>
    <a href={social.twitter} class="flex h-8 w-8 items-center justify-center rounded-full border border-white/5 bg-zinc-900/50 text-zinc-400 transition-all duration-300 hover:border-white/20 hover:text-white" aria-label="Twitter">
      <Icon name="twitter" size={15} />
    </a>
  </div>
</header>

<!-- Compact nav for small screens -->
<nav class="relative z-10 mx-auto flex w-full max-w-5xl items-center gap-6 px-6 pb-2 font-mono text-[10px] tracking-widest text-zinc-400 sm:hidden">
  {
    links.map((link) => {
      const active = link.match(here);
      return (
        <a href={link.href} aria-current={active ? 'page' : undefined} class:list={['uppercase no-underline', active ? 'text-white' : 'hover:text-white']}>
          {link.label}
        </a>
      );
    })
  }
</nav>
