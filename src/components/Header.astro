---
const base = import.meta.env.BASE_URL;
const path = (p: string) => `${base.replace(/\/$/, '')}/${p}`.replace(/\/+/g, '/');

const links = [
  { href: base, label: 'Home' },
  { href: path('articles'), label: 'Articles' },
  { href: path('projects'), label: 'Projects' },
  { href: path('about'), label: 'About' },
];

const current = Astro.url.pathname.replace(/\/$/, '');
---

<header class="site-header">
  <nav>
    <a class="brand" href={base}>acroistrash</a>
    <ul>
      {
        links.map((link) => {
          const href = link.href.replace(/\/$/, '') || '/';
          const isActive = current === href || (href !== base.replace(/\/$/, '') && current.startsWith(href));
          return (
            <li>
              <a href={link.href} aria-current={isActive ? 'page' : undefined}>
                {link.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 80%, transparent);
    backdrop-filter: saturate(160%) blur(10px);
  }

  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .brand {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.35rem;
    letter-spacing: -0.02em;
    background: var(--gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .brand:hover {
    text-decoration: none;
    opacity: 0.85;
  }

  ul {
    display: flex;
    gap: 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  ul a {
    color: var(--text-muted);
  }

  ul a:hover,
  ul a[aria-current='page'] {
    color: var(--text);
    text-decoration: none;
  }

  ul a[aria-current='page'] {
    font-weight: 600;
  }
</style>
