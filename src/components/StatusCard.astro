---
import Icon from './Icon.astro';
import { status } from '../config';

// Per-tech dot colors (Tailwind classes); unknown techs fall back to the accent.
const dotFor: Record<string, string> = {
  astro: 'accent-dot',
  typescript: 'bg-blue-400',
  react: 'bg-cyan-400',
  'node.js': 'bg-green-500',
  node: 'bg-green-500',
  tailwindcss: 'bg-indigo-400',
  tailwind: 'bg-indigo-400',
  rust: 'bg-orange-500',
  go: 'bg-sky-400',
  python: 'bg-yellow-400',
  langchain: 'bg-emerald-400',
  pydantic: 'bg-rose-400',
  aws: 'bg-orange-400',
  terraform: 'bg-purple-400',
  docker: 'bg-sky-400',
};
const dot = (t: string) => dotFor[t.toLowerCase()] ?? 'accent-dot';
const toolbox = status.toolbox ?? [];
---

<div class="relative overflow-hidden rounded-2xl border border-white/10 bg-zinc-950/60 p-6 shadow-2xl backdrop-blur-xl">
  <span class="glossy-top"></span>

  <!-- Window header -->
  <div class="flex items-center justify-between border-b border-white/5 pb-6">
    <div class="flex items-center gap-2">
      <span class="h-3 w-3 rounded-full border border-red-500/30 bg-red-500/20"></span>
      <span class="h-3 w-3 rounded-full border border-yellow-500/30 bg-yellow-500/20"></span>
      <span class="h-3 w-3 rounded-full border border-emerald-500/30 bg-emerald-500/20"></span>
    </div>
    <span class="flex items-center gap-1.5 font-mono text-[11px] tracking-wider text-zinc-500">
      <span class="h-1.5 w-1.5 rounded-full bg-zinc-500"></span> ~/status
    </span>
  </div>

  {
    status.availableForHire && (
      <div class="pt-6">
        <div class="inline-flex w-full items-center justify-between rounded-xl border border-emerald-500/10 bg-emerald-500/5 p-3.5">
          <div class="flex items-center gap-3">
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75" />
              <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500" />
            </span>
            <span class="font-mono text-[11px] font-semibold tracking-wider text-emerald-400">AVAILABLE FOR HIRE</span>
          </div>
        </div>
      </div>
    )
  }

  <!-- Data rows -->
  <dl class="space-y-1 pt-6 font-mono text-sm">
    {
      status.nowListening && (
        <div class="flex items-center justify-between border-b border-white/5 py-2">
          <dt class="flex items-center gap-3">
            <span class="w-5 text-center text-zinc-500"><Icon name="music" size={14} /></span>
            <span class="text-xs font-light text-zinc-400">listening</span>
          </dt>
          <dd class="text-xs font-semibold tracking-wide text-white">{status.nowListening}</dd>
        </div>
      )
    }
    {
      typeof status.dayStreak === 'number' && (
        <div class="flex items-center justify-between border-b border-white/5 py-2">
          <dt class="flex items-center gap-3">
            <span class="w-5 text-center text-amber-500/80"><Icon name="flame" size={14} /></span>
            <span class="text-xs font-light text-zinc-400">streak</span>
          </dt>
          <dd class="rounded-full border border-amber-500/20 bg-amber-500/10 px-2 py-0.5 text-xs font-semibold tracking-wide text-white">
            {status.dayStreak} days
          </dd>
        </div>
      )
    }
    <div class="flex items-center justify-between py-2">
      <dt class="flex items-center gap-3">
        <span class="w-5 text-center text-zinc-500"><Icon name="sparkles" size={14} /></span>
        <span class="text-xs font-light text-zinc-400">status</span>
      </dt>
      <dd class="accent-text text-xs font-medium capitalize tracking-wide">shipping</dd>
    </div>
  </dl>

  {
    toolbox.length > 0 && (
      <div class="mt-6 space-y-4 border-t border-white/5 pt-8">
        <div class="flex items-center justify-between">
          <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-zinc-500">Toolbox</span>
          <span class="font-mono text-[9px] text-zinc-600">{toolbox.length} CURRENT FLAVORS</span>
        </div>
        <div class="flex flex-wrap gap-2">
          {toolbox.map((tech) => (
            <div class="flex items-center gap-1.5 rounded-xl border border-white/5 bg-zinc-900/60 px-3 py-1.5 transition-all duration-300 hover:border-white/20 hover:bg-zinc-900">
              <span class:list={['h-1.5 w-1.5 rounded-full', dot(tech)]} />
              <span class="font-mono text-[11px] text-zinc-300">{tech}</span>
            </div>
          ))}
        </div>
      </div>
    )
  }
</div>
