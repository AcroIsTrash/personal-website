---
interface Props {
  tags?: string[];
}

const { tags = [] } = Astro.props;

// Palette of accent hues; a tag always maps to the same color.
const palette = [
  'var(--violet)',
  'var(--pink)',
  'var(--cyan)',
  'var(--amber)',
  'var(--green)',
];

function colorFor(tag: string): string {
  let hash = 0;
  for (let i = 0; i < tag.length; i++) {
    hash = (hash * 31 + tag.charCodeAt(i)) >>> 0;
  }
  return palette[hash % palette.length];
}
---

{
  tags.length > 0 && (
    <ul class="tags">
      {tags.map((tag) => (
        <li class="tag" style={`--tag-color: ${colorFor(tag)}`}>
          {tag}
        </li>
      ))}
    </ul>
  )
}
