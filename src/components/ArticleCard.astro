---
import FormattedDate from './FormattedDate.astro';
import TagList from './TagList.astro';
import { accentFor } from '../utils/accent';

interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
}

const { href, title, description, pubDate, tags = [] } = Astro.props;
---

<li class="card" style={`--card-accent: ${accentFor(title)}`}>
  <h3><a href={href}>{title}</a></h3>
  <p class="muted date"><FormattedDate date={pubDate} /></p>
  <p>{description}</p>
  <TagList tags={tags} />
</li>

<style>
  .date {
    font-size: 0.85rem;
    margin-top: 0.1rem;
  }
</style>
