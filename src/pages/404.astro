---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Page not found" description="404 — page not found.">
  <div class="flex flex-col items-center py-20 text-center">
    <h1 class="accent-clip text-7xl font-black tracking-tight">404</h1>
    <p class="mt-4 text-zinc-400">Sorry, that page doesn't exist.</p>
    <a href={`${base}/`} class="accent-gradient accent-glow mt-8 flex items-center gap-2 rounded-xl px-5 py-2.5 text-sm font-bold text-white no-underline transition-all hover:-translate-y-0.5 hover:opacity-90">
      Back home <Icon name="arrow-right" size={16} />
    </a>
  </div>
</BaseLayout>
