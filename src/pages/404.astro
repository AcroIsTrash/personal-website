---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Page not found" description="404 — page not found.">
  <div class="flex flex-col items-center py-20 text-center">
    <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-zinc-500">// Signal lost</span>
    <h1 class="accent-clip mt-3 font-display text-7xl font-extrabold tracking-tight">404</h1>
    <p class="mt-4 font-light text-zinc-400">Sorry, that page doesn't exist.</p>
    <a href={`${base}/`} class="accent-gradient mt-8 inline-flex items-center gap-2 rounded-xl px-5 py-3 text-xs font-semibold text-white no-underline transition-all hover:-translate-y-0.5 hover:opacity-90">
      Back home <Icon name="arrow-right" size={14} />
    </a>
  </div>
</BaseLayout>
