---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => Number(b.data.featured) - Number(a.data.featured)
);

const withCategory = projects.map((p) => ({ ...p, category: p.data.tags[0] ?? 'misc' }));
const categories = ['all', ...Array.from(new Set(withCategory.map((p) => p.category)))];
const total = withCategory.length;
---

<BaseLayout title="Projects" description="Projects by acroistrash." wide>
  <div class="space-y-8">
    <div class="flex flex-col justify-between gap-4 pb-2 sm:flex-row sm:items-center">
      <div class="space-y-2">
        <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-zinc-500">// Things I've Built</span>
        <h1 class="font-display text-4xl font-extrabold tracking-tight text-white">Projects</h1>
      </div>
      <div class="flex flex-wrap items-center gap-1 rounded-xl border border-white/5 bg-zinc-900/60 p-1" id="filters">
        {
          categories.map((cat, i) => (
            <button
              type="button"
              data-filter-btn={cat}
              class:list={[
                'rounded-lg px-4 py-2 font-mono text-[11px] uppercase tracking-widest transition-all duration-300',
                i === 0 ? 'accent-gradient text-white' : 'text-zinc-400 hover:text-white',
              ]}
            >
              {cat}
            </button>
          ))
        }
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2" id="project-grid">
      {
        withCategory.map((p, i) => (
          <ProjectCard
            href={`${base}/projects/${p.slug}/`}
            title={p.data.title}
            description={p.data.description}
            tags={p.data.tags}
            repo={p.data.repo}
            link={p.data.link}
            index={i + 1}
            total={total}
            variant="full"
          />
        ))
      }
    </div>
  </div>

  <script>
    const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-filter-btn]'));
    const cards = Array.from(document.querySelectorAll<HTMLElement>('#project-grid [data-filter]'));
    const onCls = ['accent-gradient', 'text-white'];
    const offCls = ['text-zinc-400', 'hover:text-white'];

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filterBtn;
        buttons.forEach((b) => {
          const on = b === btn;
          onCls.forEach((c) => b.classList.toggle(c, on));
          offCls.forEach((c) => b.classList.toggle(c, !on));
        });
        cards.forEach((card) => {
          card.classList.toggle('hidden', !(filter === 'all' || card.dataset.category === filter));
        });
      });
    });
  </script>
</BaseLayout>
