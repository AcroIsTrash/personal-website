---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => Number(b.data.featured) - Number(a.data.featured)
);

// A project's "category" is its first tag; build the filter list from them.
const withCategory = projects.map((p) => ({ ...p, category: p.data.tags[0] ?? 'misc' }));
const categories = ['all', ...Array.from(new Set(withCategory.map((p) => p.category)))];
---

<BaseLayout title="Projects" description="Projects by acroistrash." wide>
  <div class="space-y-8">
    <div class="space-y-4 py-6 text-center">
      <h1 class="text-4xl font-black tracking-tight">Active Repositories</h1>
      <p class="mx-auto max-w-lg text-zinc-400">
        Latest visual designs, tooling, core APIs, and experiments.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-2 pt-4" id="filters">
        {
          categories.map((cat, i) => (
            <button
              type="button"
              data-filter-btn={cat}
              class:list={[
                'rounded-xl px-4 py-1.5 text-xs font-semibold uppercase tracking-wider transition-all duration-300',
                i === 0
                  ? 'accent-gradient text-white shadow-lg'
                  : 'border border-white/5 bg-[#130e23]/80 text-zinc-400 hover:text-zinc-100',
              ]}
            >
              {cat}
            </button>
          ))
        }
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3" id="project-grid">
      {
        withCategory.map((p) => (
          <ProjectCard
            href={`${base}/projects/${p.slug}/`}
            title={p.data.title}
            description={p.data.description}
            tags={p.data.tags}
            repo={p.data.repo}
            link={p.data.link}
            category={p.category}
            variant="full"
          />
        ))
      }
    </div>
  </div>

  <script>
    const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-filter-btn]'));
    const cards = Array.from(document.querySelectorAll<HTMLElement>('#project-grid [data-filter]'));
    const activeCls = ['accent-gradient', 'text-white', 'shadow-lg'];
    const idleCls = ['border', 'border-white/5', 'bg-[#130e23]/80', 'text-zinc-400', 'hover:text-zinc-100'];

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filterBtn;
        buttons.forEach((b) => {
          const on = b === btn;
          b.classList.toggle('text-zinc-400', !on);
          activeCls.forEach((c) => b.classList.toggle(c, on));
          idleCls.forEach((c) => b.classList.toggle(c, !on));
        });
        cards.forEach((card) => {
          const show = filter === 'all' || card.dataset.category === filter;
          card.classList.toggle('hidden', !show);
        });
      });
    });
  </script>
</BaseLayout>
