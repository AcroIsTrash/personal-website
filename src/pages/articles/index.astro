---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Icon from '../../components/Icon.astro';
import { readingTime } from '../../utils/readingTime';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Articles" description="Articles by acroistrash." wide>
  <div class="mx-auto max-w-4xl space-y-8">
    <div class="space-y-4 py-6 text-center">
      <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-zinc-500">// The Dev Journal</span>
      <h1 class="font-display text-4xl font-extrabold tracking-tight text-white">Articles</h1>
      <p class="mx-auto max-w-md text-sm font-light text-zinc-400">
        Architectural insights, design notes, lessons from failures, and code snippets.
      </p>
      <div class="relative mx-auto max-w-md pt-2">
        <span class="absolute left-3.5 top-1/2 mt-1 -translate-y-1/2 text-zinc-500">
          <Icon name="search" size={15} />
        </span>
        <input
          type="text"
          id="article-search"
          placeholder="Search articles..."
          class="accent-ring-focus w-full rounded-xl border border-white/10 bg-zinc-900/60 py-2.5 pl-10 pr-4 text-sm text-zinc-100 placeholder-zinc-600 transition-colors"
        />
      </div>
    </div>

    <div class="space-y-4" id="article-list">
      {
        articles.map((a) => (
          <ArticleCard
            href={`${base}/articles/${a.slug}/`}
            title={a.data.title}
            date={fmt(a.data.pubDate)}
            readTime={readingTime(a.body)}
            excerpt={a.data.description}
            tags={a.data.tags}
          />
        ))
      }
    </div>
    <p id="no-results" class="hidden py-8 text-center font-mono text-xs text-zinc-500">No articles match your search.</p>
  </div>

  <script>
    const input = document.getElementById('article-search') as HTMLInputElement | null;
    const cards = Array.from(document.querySelectorAll<HTMLElement>('#article-list [data-search]'));
    const empty = document.getElementById('no-results');

    input?.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase();
      let visible = 0;
      cards.forEach((card) => {
        const hay = `${card.dataset.title} ${card.dataset.tags}`;
        const show = q === '' || hay.includes(q);
        card.classList.toggle('hidden', !show);
        if (show) visible++;
      });
      empty?.classList.toggle('hidden', visible !== 0);
    });
  </script>
</BaseLayout>
